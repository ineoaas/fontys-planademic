@page
@model Planademic.Web.Pages.Account.RegisterModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Register";
}

<div class="auth-center">
    <div class="auth-form-wrap">
        <h2 class="auth-form-title">Create account</h2>

        <form method="post" class="auth-form">
            @Html.AntiForgeryToken()

            @if (Model.ErrorMessage != null)
            {
                <div class="auth-error">@Model.ErrorMessage</div>
            }

            <div style="display:flex; gap:0.75rem;">
                <div class="field-group" style="flex:1">
                    <label class="field-label" for="firstName">First name</label>
                    <input class="field-input" type="text" id="firstName" name="FirstName"
                           placeholder="Jane" value="@Model.FirstName" />
                </div>
                <div class="field-group" style="flex:1">
                    <label class="field-label" for="lastName">Last name</label>
                    <input class="field-input" type="text" id="lastName" name="LastName"
                           placeholder="Doe" value="@Model.LastName" />
                </div>
            </div>

            <div class="field-group">
                <label class="field-label" for="email">Email address</label>
                <input class="field-input" type="email" id="email" name="Email"
                       placeholder="you@student.fontys.nl" value="@Model.Email" />
            </div>

            <div class="field-group">
                <label class="field-label" for="password">Password</label>
                <input class="field-input" type="password" id="password" name="Password"
                       placeholder="••••••••" />
            </div>

            <div class="field-group">
                <label class="field-label" for="confirmPassword">Confirm password</label>
                <input class="field-input" type="password" id="confirmPassword" name="ConfirmPassword"
                       placeholder="••••••••" />
            </div>

            <button type="submit" class="btn btn-primary btn-full btn-lg">
                Create account →
            </button>

            <p class="auth-switch">
                Already have an account? <a asp-page="/Account/Login">Log in here</a>
            </p>
        </form>
    </div>
</div>
