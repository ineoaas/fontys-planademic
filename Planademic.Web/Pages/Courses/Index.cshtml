@model Planademic.Web.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "My Courses";
    ViewData["ActivePage"] = "Courses";
}

@section TopbarActions {
    <button class="btn btn-primary btn-sm" id="joinCourseBtn">+ Join course</button>
}

<div class="modal-overlay" id="joinModal">
    <div class="modal">
        <div class="modal-header">
            <span class="modal-title">Join a course</span>
            <button class="modal-close" id="closeModal">✕</button>
        </div>
        <div class="modal-body">
            <p class="modal-hint">Ask your teacher for the course join code.</p>
            <div class="field-group">
                <label class="field-label" for="joinCode">Join code</label>
                <input class="field-input" id="joinCode" type="text" placeholder="e.g. SD-4829" />
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost btn-sm" id="cancelJoin">Cancel</button>
            <button class="btn btn-primary btn-sm" disabled>Join course</button>
        </div>
    </div>
</div>

