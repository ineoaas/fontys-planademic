@page
@model Planademic.Web.Pages.Teacher.DashboardModel
@{
    ViewData["Title"] = "Teacher View";
    ViewData["ActivePage"] = "TeacherDashboard";
}

@section TopbarActions {
    <a asp-page="/Courses/Index" class="btn btn-primary btn-sm">+ Create course</a>
}

@if (!Model.Courses.Any())
{
    <p style="color: var(--text-muted);">No courses yet. <a asp-page="/Courses/Index">Create your first course.</a></p>
}

@foreach (var course in Model.Courses)
{
    <div class="card" style="margin-bottom: 1.25rem;">
        <div class="card-header">
            <span class="card-title">@course.Name</span>
        </div>
        <div class="card-body">
            <div class="course-detail-row">
                <div class="course-detail-item">
                    <span class="detail-label">Join code</span>
                    <span class="detail-value detail-code">@course.JoinCode</span>
                </div>
                <div class="course-detail-item">
                    <span class="detail-label">Created</span>
                    <span class="detail-value">@course.CreatedAt.ToString("MMM d, yyyy")</span>
                </div>
            </div>
        </div>
    </div>
}
