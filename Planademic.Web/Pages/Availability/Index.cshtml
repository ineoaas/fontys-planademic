@page
@model Planademic.Web.Pages.Availability.IndexModel
@{
    ViewData["Title"] = "My Availability";
    ViewData["ActivePage"] = "Availability";
}

@section TopbarActions {
    <button class="btn btn-primary btn-sm" id="saveAvail" disabled>Save changes</button>
}

@Html.AntiForgeryToken()

<p class="page-hint">Click slots to toggle your free time. The scheduling engine uses this to build your study roadmap.</p>

<div class="card">
    <div class="card-body">
        <div class="avail-grid">
            <div class="ag-cell ag-header ag-corner"></div>
            <div class="ag-cell ag-header">Mon</div>
            <div class="ag-cell ag-header">Tue</div>
            <div class="ag-cell ag-header">Wed</div>
            <div class="ag-cell ag-header">Thu</div>
            <div class="ag-cell ag-header">Fri</div>
            <div class="ag-cell ag-header">Sat</div>
            <div class="ag-cell ag-header">Sun</div>

            @{
                var timeLabels = new[] { "08:00 – 10:00", "10:00 – 12:00", "12:00 – 14:00", "14:00 – 16:00", "16:00 – 18:00", "18:00 – 20:00" };
            }

            @for (int slot = 0; slot < 6; slot++)
            {
                <div class="ag-cell ag-time">@timeLabels[slot]</div>
                @for (int day = 0; day < 7; day++)
                {
                    bool active = Model.SavedSlots.Contains((day, slot));
                    <div class="ag-cell ag-slot @(active ? "active" : "")" data-day="@day" data-slot="@slot">
                        @if (active) { <span>Free</span> }
                    </div>
                }
            }
        </div>

        <div class="avail-legend">
            <span class="avail-legend-item">
                <span class="avail-swatch swatch-free"></span> Free
            </span>
            <span class="avail-legend-item">
                <span class="avail-swatch swatch-busy"></span> Busy
            </span>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const saveBtn = document.getElementById('saveAvail');

    document.querySelectorAll('.ag-slot').forEach(cell => {
        cell.addEventListener('click', () => {
            cell.classList.toggle('active');
            cell.innerHTML = cell.classList.contains('active') ? '<span>Free</span>' : '';
            if (saveBtn) saveBtn.disabled = false;
        });
    });

    saveBtn.addEventListener('click', async () => {
        const slots = [];
        document.querySelectorAll('.ag-slot.active').forEach(cell => {
            slots.push({ day: parseInt(cell.dataset.day), slot: parseInt(cell.dataset.slot) });
        });

        const response = await fetch('?handler=Save', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            },
            body: JSON.stringify(slots)
        });

        if (response.ok) {
            saveBtn.disabled = true;
        }
    });
</script>
}
