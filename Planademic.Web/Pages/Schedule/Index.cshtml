@page
@model Planademic.Web.Pages.Schedule.IndexModel
@{
    ViewData["Title"] = "Study Schedule";
    ViewData["ActivePage"] = "Schedule";
    var days = new[] { DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday };
}

@section TopbarActions {
    <div style="display:flex;gap:.5rem;">
        <a asp-page="/Schedule/Index" class="btn btn-primary btn-sm">Regenerate</a>
    </div>
}

<div class="card" style="margin-bottom: 1.25rem;">
    <div class="card-header">
        <span class="card-title">Week of @Model.WeekStart.ToString("MMM d") – @Model.WeekEnd.ToString("MMM d, yyyy")</span>
    </div>
    <div class="card-body p0">

        @for (int d = 0; d < 7; d++)
        {
            var date = Model.WeekStart.AddDays(d);
            var dayEntries = Model.Schedule.Where(s => s.Date == date).ToList();
            var rowClass = d == 6 ? "week-row week-row-last" : "week-row";
            <div class="@rowClass">
                <span class="week-day">@date.ToString("ddd MMM d")</span>
                <div class="week-slots">
                    @if (dayEntries.Any())
                    {
                        @foreach (var entry in dayEntries)
                        {
                            var color = entry.Task.Complexity >= 7 ? "slot-indigo"
                                      : entry.Task.Complexity >= 4 ? "slot-teal"
                                      : "slot-amber";
                            <div class="week-slot-line">
                                <span class="ws-time">@entry.StartTime.ToString("HH:mm") – @entry.EndTime.ToString("HH:mm")</span>
                                <div class="slot-bar @color">@entry.Task.Title</div>
                            </div>
                        }
                    }
                    else
                    {
                        <span style="color: var(--text-muted); font-size: 0.85rem;">No sessions</span>
                    }
                </div>
            </div>
        }

    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">Workload heatmap</span>
    </div>
    <div class="card-body">
        <div class="heatmap-grid">
            <div class="hm-corner"></div>
            @foreach (var label in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
            {
                <div class="hm-daylabel">@label</div>
            }

            <div class="hm-rowlabel">Morning</div>
            @foreach (var d in days) { <div class="hm-cell hm-@Model.HeatmapLevel(d, 0)"></div> }

            <div class="hm-rowlabel">Afternoon</div>
            @foreach (var d in days) { <div class="hm-cell hm-@Model.HeatmapLevel(d, 1)"></div> }

            <div class="hm-rowlabel">Evening</div>
            @foreach (var d in days) { <div class="hm-cell hm-@Model.HeatmapLevel(d, 2)"></div> }
        </div>

        <div class="heatmap-legend">
            <span>Low</span>
            <div class="hm-cell hm-0 hm-legend-cell"></div>
            <div class="hm-cell hm-1 hm-legend-cell"></div>
            <div class="hm-cell hm-2 hm-legend-cell"></div>
            <div class="hm-cell hm-3 hm-legend-cell"></div>
            <div class="hm-cell hm-4 hm-legend-cell"></div>
            <span>High</span>
        </div>
    </div>
</div>
