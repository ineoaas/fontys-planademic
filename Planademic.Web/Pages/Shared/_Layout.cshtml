<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Planademic</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-shell">

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-mark">P</div>
            <span class="brand-name">Planademic</span>
        </div>

        <nav class="sidebar-nav">
            <p class="nav-group-label">Overview</p>
            <a asp-page="/Dashboard"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")">
                <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><rect x="1.5" y="1.5" width="6" height="6" rx="1.2" fill="currentColor" opacity=".8"/><rect x="10.5" y="1.5" width="6" height="6" rx="1.2" fill="currentColor" opacity=".8"/><rect x="1.5" y="10.5" width="6" height="6" rx="1.2" fill="currentColor" opacity=".8"/><rect x="10.5" y="10.5" width="6" height="6" rx="1.2" fill="currentColor" opacity=".8"/></svg>
                Dashboard
            </a>
            @if (User.IsInRole("Student"))
            {
                <a asp-page="/Schedule/Index"
                   class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Schedule" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.4"/><path d="M9 5.5v3.75l2.25 2.25" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                    My Schedule
                </a>
            }

            @if (User.IsInRole("Student"))
            {
                <p class="nav-group-label">Tasks</p>
                <a asp-page="/StudentTasks/Index"
                   class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "StudentTasks" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><path d="M4 4.5h10M4 9h7M4 13.5h5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                    My Tasks
                </a>
            }

            <p class="nav-group-label">Courses</p>
            <a asp-page="/Courses/Index"
               class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Courses" ? "active" : "")">
                <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><rect x="2" y="3.5" width="14" height="11" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M5.5 3.5V2.5a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v1" stroke="currentColor" stroke-width="1.4"/><path d="M5 8.5h8M5 12h4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                My Courses
            </a>
            @if (User.IsInRole("Student"))
            {
                <a asp-page="/Availability/Index"
                   class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Availability" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><rect x="2" y="3" width="14" height="13" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M6 2v2M12 2v2M2 7.5h14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                    Availability
                </a>
            }

            @if (User.IsInRole("Teacher"))
            {
                <p class="nav-group-label">Teacher</p>
                <a asp-page="/Teacher/Dashboard"
                   class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "TeacherDashboard" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><rect x="2" y="2" width="14" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M6 16h6M9 12v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                    Teacher View
                </a>
                <a asp-page="/CourseTasks/Index"
                   class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "CourseTasks" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><path d="M4 4.5h10M4 9h7M4 13.5h5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                    Course Tasks
                </a>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="user-row">
                @{
                    var fullName = User.Identity?.Name ?? "User";
                    var initials = string.Concat(fullName.Split(' ').Where(p => p.Length > 0).Select(p => p[0])).ToUpper();
                    var role = User.IsInRole("Teacher") ? "Teacher" : "Student";
                }
                <div class="user-avatar">@initials</div>
                <div class="user-info">
                    <span class="user-name">@fullName</span>
                    <span class="user-role">@role</span>
                </div>
            </div>
            <a asp-page="/Account/Login" class="sidebar-link logout-link">
                <svg class="nav-icon" viewBox="0 0 18 18" fill="none"><path d="M12 9H4m0 0 2.5-2.5M4 9l2.5 2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M8.5 5.5V4a1.5 1.5 0 0 1 1.5-1.5h4A1.5 1.5 0 0 1 15.5 4v10A1.5 1.5 0 0 1 14 15.5h-4A1.5 1.5 0 0 1 8.5 14v-1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                Log out
            </a>
        </div>
    </aside>

    <div class="app-content" id="appContent">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <span></span><span></span><span></span>
            </button>
            <span class="topbar-page">@ViewData["Title"]</span>
            <div class="topbar-right">
                @await RenderSectionAsync("TopbarActions", required: false)
            </div>
        </header>

        <main class="page-body">
            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
